# 环境配置示例
## LLM
LLM_API_KEY = Your api key
LLM_MODEL_ID = Your model
LLM_BASE_URL = Your url


## SerpApi
SERPAPI_API_KEY="Your SerpApi api key"

# - Qdrant Neo4j 均有免费版本, 学习足够使用
## Qdrant 向量数据库配置 - https://cloud.qdrant.io/
QDRANT_URL= Your Cluster Url
QDRANT_API_KEY= Your Qdrant api key

##  Qdrant集合配置
QDRANT_COLLECTION=hello_agents_vectors
QDRANT_VECTOR_SIZE=384
QDRANT_DISTANCE=cosine
QDRANT_TIMEOUT=30

## Neo4j 图数据库配置 - https://neo4j.com/cloud/aura/
### 以下配置在Neo4j下载的文件中
NEO4J_URI=neo4j+s://110dece4.databases.neo4j.io
NEO4J_USERNAME=110dece4
NEO4J_PASSWORD=KyqbTeTtwtJiUyXsyqBWNjDFen5XuGrDKYnwhXivLf8
NEO4J_DATABASE=110dece4
AURA_INSTANCEID=110dece4
AURA_INSTANCENAME=Free instance

## Neo4j连接配置
NEO4J_MAX_CONNECTION_LIFETIME=3600
NEO4J_MAX_CONNECTION_POOL_SIZE=50
NEO4J_CONNECTION_TIMEOUT=60

## 嵌入（Embedding）配置示例
EMBED_MODEL_TYPE=Ollama

## Ollama Embedding
EMBED_MODEL_MODEL=qwen3-embedding:4b
EMBED_MODEL_BASE_URL=http://localhost:11434